    "@walty/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.6.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "socket.io-client": "^4.8.3",
