# ============================================
# WALTY - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ============================================
# REQUIRED - The app won't work without these
# ============================================

# PostgreSQL database URL
# Docker Compose: use the `db` service hostname
#   DATABASE_URL=postgresql://wallet:wallet@db:5432/wallet
# Local development (outside Docker):
#   DATABASE_URL=postgresql://wallet:wallet@localhost:5432/wallet
DATABASE_URL=postgresql://wallet:wallet@db:5432/wallet

# Secret used to sign and verify JWTs
# Generate a secure one: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-this-in-production

# HMAC key for deriving the PIN challenge used in server-side wallet backup
# Generate a secure one: openssl rand -base64 32
SERVER_PEPPER=your-pepper-key-here-change-this-in-production

# Alchemy API key for multichain RPC (Ethereum, Arbitrum, Base, Optimism, Polygon)
# Without this key, balances and transactions will fail — public RPCs are unreliable
# Get a free key at: https://www.alchemy.com/
ALCHEMY_API_KEY=

# 0x API key for token swaps
# Without this key, swap calls will fail with 401
# Get a free key at: https://0x.org/docs/api
ZEROX_API_KEY=

# ============================================
# OPTIONAL - Degrade gracefully if missing
# ============================================

# Ankr API key for multichain RPC (fallback between Alchemy and public RPCs)
# Without this key, Ankr is skipped and free public endpoints are used
# Get one at: https://www.ankr.com/rpc/
ANKR_API_KEY=

# 1inch API key for swap fallback
# Without this key, only 0x is used for swaps
# Get one at: https://portal.1inch.dev/
ONEINCH_API_KEY=

# CoinGecko API key for token prices and images
# Without this key, the app works but with stricter rate limits
# Get one at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Override CoinGecko base URL (rarely needed)
# COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3

# Force the Secure flag on the JWT cookie (useful for local HTTPS development)
# If not set, Secure is only applied in production (NODE_ENV=production)
# COOKIE_SECURE=true

# ============================================
# AUTOMATIC / NOTES
# ============================================
# NODE_ENV is set automatically (development/production)
# NEXT_PUBLIC_RPC_URL is reserved for future use and is not used today
# Pricing providers (CoinGecko / DefiLlama) must be called from API routes,
# not directly from the browser, or CSP will block them.
