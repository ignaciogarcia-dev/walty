# ============================================
# WALTY - Environment Variables
# ============================================
#
# Quick start (local development):
#   cp .env.example .env
#   docker compose -f compose.dev.yml up -d
#   pnpm install
#   pnpm db:migrate
#   pnpm dev
#

# ============================================
# APP ENVIRONMENT
# ============================================

# "local" for development, "production" for deploy
# Local: DB via compose.dev.yml, relaxed settings
# Production: external managed DB (Supabase, Neon, DO Managed, etc.)
APP_ENV=local

# ============================================
# REQUIRED
# ============================================

# PostgreSQL
# Local (compose.dev.yml):
DATABASE_URL=postgresql://wallet:wallet@localhost:5432/wallet
# Production (Supabase example):
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require

# JWT signing secret (HS256). Never use NEXT_PUBLIC_ — this must stay server-only.
# Production: at least 32 characters (e.g. openssl rand -base64 32).
# Local dev: any non-empty string; use a long secret to mirror production.
# Same secret must be set for apps/web (cookie verify in SSR) and apps/api.
JWT_SECRET=dev-secret-change-me-to-a-long-random-string

# Browser-facing API origin. Baked into the client bundle at `next build` time
# and used by the browser for the WebSocket connection (which can't proxy
# through the Next.js rewrite). MUST be reachable from the user's browser — in
# Docker that's the host-published port (http://localhost:4000), not the service
# name. In prod set to the public Express origin and rebuild, e.g.
# `--build-arg NEXT_PUBLIC_API_BASE_URL=https://api.walty.app`.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Server-side target for the Next.js /api/* rewrite (runs inside the web server,
# so in Docker it points at the api by service name). Like NEXT_PUBLIC_*, the
# rewrite destination is baked at `next build` time — pass it as a build arg.
# Falls back to NEXT_PUBLIC_API_BASE_URL for single-origin setups; leave unset
# for plain local dev (web + api both on localhost).
# API_INTERNAL_URL=http://api:4000

# Express listen port and the web origin it allows via CORS (must match the
# Next.js origin). Only consumed by apps/api.
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# Public domains for the Caddy reverse proxy (production droplet deploy).
# APP_DOMAIN serves the web app; API_DOMAIN serves the Express + Socket.IO API
# and is the origin POS devices point their apiBaseUrl at (keep it a dedicated
# subdomain, not a path under the web host). Caddy fetches Let's Encrypt certs
# for both automatically. Leave as "localhost" for a local/IP smoke test (Caddy
# uses a self-signed cert then). Production example:
#   APP_DOMAIN=www.walty.io
#   API_DOMAIN=api.walty.io
APP_DOMAIN=localhost
API_DOMAIN=localhost

# Alchemy API key for multichain RPC (Ethereum, Arbitrum, Base, Optimism, Polygon)
# Get a free key at: https://www.alchemy.com/
# Use the same value in NEXT_PUBLIC_ALCHEMY_API_KEY so wallet/sign flows in the
# browser can call Alchemy (server-only env vars are not available client-side).
ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Secret for the internal payment reconciler endpoint
# Generate one: openssl rand -base64 32
PAYMENTS_RECONCILE_SECRET=

# ============================================
# OPTIONAL — degrade gracefully if missing
# ============================================

# CoinGecko API key for prices and token images
# COINGECKO_API_KEY=

# Enabled chains — comma-separated chain IDs (1, 42161, 8453, 10, 137)
# When unset all supported chains are enabled.
# Example: only Polygon → NEXT_PUBLIC_ENABLED_CHAINS=137
NEXT_PUBLIC_ENABLED_CHAINS=137

# Client error-reporting DSN. Leave EMPTY to keep reporting inert (the default):
# error boundaries still catch and show a fallback, but nothing is sent off the
# device. Reporting only activates with BOTH a DSN here AND explicit user
# opt-in. Payloads are always scrubbed of secrets/PII before dispatch.
NEXT_PUBLIC_ERROR_REPORTING_DSN=

# Force Secure flag on JWT cookie (useful for local HTTPS)
# COOKIE_SECURE=true

# ============================================
# GASLESS RELAY (sponsor wallet)
# ============================================

# Private key of the sponsor wallet that pays MATIC gas on Polygon.
# Create a dedicated wallet for this — never reuse a user wallet.
# Server-only: NEVER prefix with NEXT_PUBLIC_
# Generate: cast wallet new  (foundry)  or  node -e "const {Wallet}=require('ethers');console.log(Wallet.createRandom().privateKey)"
SPONSOR_PRIVATE_KEY=0x

# Public address of the sponsor wallet (same wallet as above, used client-side for permit spender)
NEXT_PUBLIC_SPONSOR_ADDRESS=0x

# Platform fee in basis points (100 = 1%, 50 = 0.5%)
NEXT_PUBLIC_FEE_BPS=100

# Your wallet address that receives the fee on each relay
NEXT_PUBLIC_FEE_RECIPIENT=0x

# ============================================
# SAFE TREASURY DEPLOYMENT
# ============================================

# Server EOA that pays gas to deploy business Safes (Amoy for now). 0x-prefixed.
SAFE_DEPLOYER_PRIVATE_KEY=

# Chain to deploy treasuries on. 80002 = Polygon Amoy (testnet), 137 = Polygon mainnet.
SAFE_CHAIN_ID=80002

# Optional RPC override for Safe/Roles ops (e.g. a local anvil fork). Falls back to the public RPC for the chain.
# SAFE_RPC_URL=http://127.0.0.1:8546

# ============================================
# MPC ENGINE — SERVER SHARE STORE (Fase 3b)
# ============================================

# Selects how the per-share DEK is wrapped at rest.
#   unset / "local" -> LocalDevKms (dev only, KEK in process memory)
#   "aws"           -> AWS KMS (production)
# MPC_KMS_PROVIDER=aws

# --- AWS KMS (production) -------------------------------------------------
# Required when MPC_KMS_PROVIDER=aws. The KMS key used to wrap MPC share DEKs;
# accepts a key ID, ARN, or alias (e.g. alias/walty-mpc-shares).
# Credentials & region come from the standard AWS provider chain
# (AWS_REGION + env keys, a profile, or an IAM role on the host).
# MPC_KMS_AWS_KEY_ID=alias/walty-mpc-shares
# AWS_REGION=us-east-1

# --- LocalDevKms (development) --------------------------------------------
# DEV-ONLY KEK used by LocalDevKms to wrap MPC share DEKs at rest.
# ⚠  This is a developer convenience — NOT for production use.
# Production: set MPC_KMS_PROVIDER=aws and MPC_KMS_AWS_KEY_ID above.
#
# Generate a fresh key:
#   openssl rand -base64 32
# Example dev value (change before committing to any shared environment):
MPC_KMS_DEV_KEK=REPLACE_WITH_OUTPUT_OF__openssl_rand_-base64_32

# ============================================
# PRODUCTION NOTES
# ============================================
# - Use a managed Postgres (Supabase free tier, Neon, DO Managed Database)
# - DATABASE_URL must include ?sslmode=require for remote databases
# - Generate strong secrets: openssl rand -base64 32
# - Deploy: Digital Ocean droplet + docker-compose.yml (app only, no DB)
# - The app connects directly to the external DB via DATABASE_URL
