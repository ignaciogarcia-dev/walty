# ============================================
# WALTY - Variables de Entorno
# ============================================
# Copia este archivo a .env y completa los valores
# cp .env.example .env

# ============================================
# REQUERIDAS - Sin estas la app no funciona
# ============================================

# Base de datos PostgreSQL
# Docker Compose: usa el hostname del servicio `db`
#   DATABASE_URL=postgresql://wallet:wallet@db:5432/wallet
# Desarrollo local fuera de Docker:
#   DATABASE_URL=postgresql://wallet:wallet@localhost:5432/wallet
DATABASE_URL=postgresql://wallet:wallet@db:5432/wallet

# Secreto para firmar y verificar JWT
# Genera uno seguro: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-this-in-production

# HMAC key para derivar challenge de PIN en backup servidor
# Genera uno seguro: openssl rand -base64 32
SERVER_PEPPER=your-pepper-key-here-change-this-in-production

# ============================================
# RECOMENDADAS - Mejoran la experiencia
# ============================================

# API key de Alchemy para RPC multichain (Ethereum, Arbitrum, Base, Optimism, Polygon)
# Muy recomendada: el fallback actual de Ankr ya no funciona de forma anónima
# y responde 401 / "authenticate your request with an API key".
# Sin ALCHEMY_API_KEY, balances/RPC calls pueden fallar en el browser.
# Obtén una en: https://www.alchemy.com/
ALCHEMY_API_KEY=

# API key de 0x para swap de tokens
# Requerida para swap en producción (sin ella 0x falla con 401)
# Obtén una en: https://0x.org/docs/api
ZEROX_API_KEY=

# ============================================
# OPCIONALES - Funcionalidades adicionales
# ============================================

# API key de Ankr para RPC multichain (fallback entre Alchemy y public RPCs)
# Sin esta key, Ankr se omite y se usan los endpoints públicos gratuitos
# Obtén una en: https://www.ankr.com/rpc/
ANKR_API_KEY=

# API key de 1inch para fallback de swap
# Sin esta key, solo se usa 0x para swaps
# Obtén una en: https://portal.1inch.dev/
ONEINCH_API_KEY=

# API key de CoinGecko para precios e imágenes de tokens
# Sin esta key, funciona con rate limits más restrictivos
# Obtén una en: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Override de base URL de CoinGecko (normalmente no hace falta)
# COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3

# Fuerza flag Secure en cookie JWT (útil en desarrollo con HTTPS)
# Si no se define, se usa Secure solo en producción (NODE_ENV=production)
# COOKIE_SECURE=true

# ============================================
# AUTOMÁTICAS / NOTAS
# ============================================
# NODE_ENV se establece automáticamente (development/production)
# NEXT_PUBLIC_RPC_URL está reservada para uso futuro y hoy no se usa
# Los providers de pricing (CoinGecko / DefiLlama) deben consultarse desde API routes,
# no directamente desde el browser, o CSP los bloqueará.
