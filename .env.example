# Database connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For Docker Compose, use the service name 'db' as the host
DATABASE_URL=postgresql://wallet:wallet@db:5432/wallet

# JWT secret key for signing authentication tokens
# Generate a secure random string (e.g., openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-key-here

# Server pepper for cryptographic challenges
# Generate a secure random string (e.g., openssl rand -base64 32)
SERVER_PEPPER=your-server-pepper-here

# Optional: Custom RPC URL for Ethereum interactions
# If not set, will use default public RPC endpoints
NEXT_PUBLIC_RPC_URL=

# Optional: 0x Protocol API key for token swaps
# If not set, swaps will use the public API (rate limited)
ZEROX_API_KEY=

# Optional: CoinGecko API key for token images
# If not set, token images use the public API (rate limited)
COINGECKO_API_KEY=
